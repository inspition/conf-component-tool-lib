{
  "name": "conf-component-tool-lib",
  "version": "1.0.0",
  "private": true,
  "description": "配置化组件工具库 - Monorepo",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "build:shared": "pnpm --filter @conf-tool/shared run build",
    "build:vue2-element": "pnpm --filter @conf-tool/vue2-element run build",
    "build:vue2-vant": "pnpm --filter @conf-tool/vue2-vant run build",
    "build:vue3-element-plus": "pnpm --filter @conf-tool/vue3-element-plus run build",
    "dev": "pnpm -r --filter './packages/*' run dev",
    "clean": "pnpm -r --filter './packages/*' exec rimraf dist",
    "new-package": "node scripts/new-package.js"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
